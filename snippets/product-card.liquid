{%- comment -%}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
  Optional: {% render 'product-card', product: product, lazy: true %}
{%- endcomment -%}

{%- liquid
  assign lazy = lazy | default: true
  assign current_variant = product.selected_or_first_available_variant
  assign featured_image = product.featured_image
  assign second_image = product.images[1]
  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
  assign sold_out = true
  if current_variant.available
    assign sold_out = false
  endif
-%}

<div class="product-card" data-product-card data-product-id="{{ product.id }}">
  <div class="product-card__media">
    {%- if featured_image -%}
      <img
        class="product-card__img product-card__img--primary"
        src="{{ featured_image | image_url: width: 600 }}"
        alt="{{ featured_image.alt | escape | default: product.title | escape }}"
        width="300"
        height="400"
        loading="{% if lazy %}lazy{% else %}eager{% endif %}"
      >
    {%- endif -%}

    {%- if second_image -%}
      <img
        class="product-card__img product-card__img--hover"
        src="{{ second_image | image_url: width: 600 }}"
        alt="{{ second_image.alt | escape | default: product.title | escape }}"
        width="300"
        height="400"
        loading="lazy"
      >
    {%- endif -%}

    {%- if on_sale -%}
      {%- assign save_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100.0 | divided_by: current_variant.compare_at_price | round -%}
      <span class="product-card__badge">{{ 'products.product.save_pct' | t: pct: save_pct }}</span>
    {%- elsif sold_out -%}
      <span class="product-card__badge" style="background: var(--lc-text-light);">{{ 'products.product.sold_out' | t }}</span>
    {%- endif -%}

    <button class="product-card__wishlist" aria-label="{{ 'sections.header.wishlist' | t }}" data-wishlist-add="{{ product.id }}">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
      </svg>
    </button>

    {%- unless sold_out -%}
      {%- if product.has_only_default_variant -%}
        <button
          class="product-card__quick-add"
          data-quick-add
          data-variant-id="{{ current_variant.id }}"
        >
          {{ 'products.quick_add.label' | t }}
        </button>
      {%- else -%}
        <a href="{{ product.url }}" class="product-card__quick-add">
          {{ 'products.quick_add.select_variant' | t }}
        </a>
      {%- endif -%}
    {%- endunless -%}
  </div>

  <div class="product-card__info">
    {%- if product.type != blank -%}
      <p class="product-card__type">{{ product.type }}</p>
    {%- endif -%}

    <h3 class="product-card__title">
      <a href="{{ product.url }}">{{ product.title }}</a>
    </h3>

    <div class="product-card__price">
      {%- if on_sale -%}
        <span class="product-card__price--sale">{{ current_variant.price | money }}</span>
        <span class="product-card__compare-price">{{ current_variant.compare_at_price | money }}</span>
      {%- else -%}
        <span>{{ current_variant.price | money }}</span>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
(function() {
  // Quick Add — single variant products
  document.querySelectorAll('[data-quick-add]').forEach(function(btn) {
    if (btn._lcBound) return;
    btn._lcBound = true;
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var variantId = parseInt(this.getAttribute('data-variant-id'), 10);
      if (!variantId || !LC.CartDrawer) return;

      this.textContent = '{{ "accessibility.loading" | t }}';
      this.disabled = true;
      var self = this;

      LC.CartDrawer.addItem(variantId, 1).then(function() {
        self.textContent = '{{ "products.product.added" | t }}';
        setTimeout(function() {
          self.textContent = '{{ "products.quick_add.label" | t }}';
          self.disabled = false;
        }, 1500);
      });
    });
  });
})();
</script>
