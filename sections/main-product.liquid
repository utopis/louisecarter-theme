<!-- ============================================ -->
<!-- PRODUCT RECOMMENDATIONS FETCH                -->
<!-- ============================================ -->
{%- if section.settings.show_recommendations -%}
  <script>
    (function() {
      var productId = {{ product.id }};
      var sectionId = '{{ section.id }}';
      var container = document.getElementById('product-recommendations');
      if (!container || container.children.length > 0) return;
      fetch(window.Shopify.routes.root + 'recommendations/products.json?product_id=' + productId + '&limit=4&section_id=' + sectionId)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (!data.products || data.products.length === 0) return;
          container.innerHTML = '';
          data.products.forEach(function(p) {
            var priceHtml = '';
            if (p.compare_at_price && p.compare_at_price > p.price) {
              priceHtml = '<span class="text-sm line-through text-lc-taupe">' + Shopify.formatMoney(p.compare_at_price) + '</span> <span class="text-sm font-medium">' + Shopify.formatMoney(p.price) + '</span>';
            } else {
              priceHtml = '<span class="text-sm font-medium">' + Shopify.formatMoney(p.price) + '</span>';
            }
            var card = document.createElement('a');
            card.href = p.url;
            card.className = 'bg-white rounded-xl overflow-hidden block hover:shadow-md transition-shadow';
            card.innerHTML =
              '<div class="relative">' +
                '<img src="' + p.featured_image + '" alt="' + (p.title || '') + '" class="w-full aspect-square object-cover" loading="lazy">' +
              '</div>' +
              '<div class="p-3">' +
                '<p class="text-sm font-medium">' + p.title + '</p>' +
                '<p class="text-xs text-lc-taupe">' + (p.product_type || '') + '</p>' +
                '<div class="flex items-baseline gap-2 mt-1">' + priceHtml + '</div>' +
              '</div>';
            container.appendChild(card);
          });
        });
    })();
  </script>
{%- endif -%}

<script>
  (function() {
    /* ---- Variant data ---- */
    var variantData = {{ product.variants | json }};
    var optionNames = {{ product.options | json }};

    function getSelectedOptions() {
      var opts = {};
      document.querySelectorAll('.swatch.active, .size-pill.active, .pouch-option.active').forEach(function(el) {
        var pos = el.dataset.optionPosition;
        if (pos) opts['option' + pos] = el.dataset.optionValue;
      });
      return opts;
    }

    function findVariant() {
      var selected = getSelectedOptions();
      return variantData.find(function(v) {
        return Object.keys(selected).every(function(key) {
          return String(v[key]) === String(selected[key]);
        });
      });
    }

    function updateVariant(variant) {
      if (!variant) return;
      document.getElementById('variant-id').value = variant.id;

      /* Update URL without reload */
      var url = new URL(window.location.href);
      url.searchParams.set('variant', variant.id);
      window.history.replaceState({}, '', url);

      /* Update prices */
      var price = Shopify.formatMoney(variant.price);
      var comparePrice = variant.compare_at_price ? Shopify.formatMoney(variant.compare_at_price) : null;
      document.querySelectorAll('.product-price').forEach(function(el) { el.textContent = price; });
      document.querySelectorAll('.product-compare-price').forEach(function(el) {
        if (comparePrice && variant.compare_at_price > variant.price) {
          el.textContent = comparePrice;
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });

      /* Update save badge */
      var saveBadges = document.querySelectorAll('.product-save-badge');
      if (variant.compare_at_price && variant.compare_at_price > variant.price) {
        var pct = Math.round(((variant.compare_at_price - variant.price) / variant.compare_at_price) * 100);
        saveBadges.forEach(function(el) { el.textContent = 'SAVE ' + pct + '%'; el.style.display = ''; });
      } else {
        saveBadges.forEach(function(el) { el.style.display = 'none'; });
      }

      /* Update ATC button */
      var mainAtc = document.getElementById('main-atc');
      if (variant.available) {
        mainAtc.disabled = false;
        mainAtc.innerHTML = 'Add to Cart &mdash; ' + price;
      } else {
        mainAtc.disabled = true;
        mainAtc.textContent = 'Sold Out';
      }
    }

    /* ---- Carousel ---- */
    var gallery = document.getElementById('gallery');
    var slides = gallery ? gallery.querySelectorAll('.carousel-slide') : [];
    var dotsContainer = document.getElementById('dots');

    if (dotsContainer && slides.length) {
      slides.forEach(function(_, i) {
        var dot = document.createElement('div');
        dot.className = 'carousel-dot' + (i === 0 ? ' active' : '');
        dot.onclick = function() { slides[i].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' }); };
        dotsContainer.appendChild(dot);
      });

      var dots = dotsContainer.querySelectorAll('.carousel-dot');
      var scrollTimeout;
      gallery.addEventListener('scroll', function() {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(function() {
          var scrollLeft = gallery.scrollLeft;
          var slideWidth = gallery.offsetWidth;
          var activeIndex = Math.round(scrollLeft / slideWidth);
          dots.forEach(function(dot, i) { dot.classList.toggle('active', i === activeIndex); });
        }, 50);
      });
    }

    /* ---- Desktop image zoom ---- */
    if (window.innerWidth >= 1024 && slides.length) {
      slides.forEach(function(slide) {
        var img = slide.querySelector('img');
        if (!img) return;
        slide.addEventListener('mousemove', function(e) {
          var rect = slide.getBoundingClientRect();
          var x = ((e.clientX - rect.left) / rect.width) * 100;
          var y = ((e.clientY - rect.top) / rect.height) * 100;
          img.style.transformOrigin = x + '% ' + y + '%';
        });
        slide.addEventListener('mouseleave', function() { img.style.transformOrigin = 'center center'; });
      });
    }

    /* ---- Swatch selector ---- */
    window.selectSwatch = function(el, name) {
      document.querySelectorAll('.swatch').forEach(function(s) { s.classList.remove('active'); });
      el.classList.add('active');
      var label = document.getElementById('selected-color');
      if (label) label.textContent = name;
      var v = findVariant();
      if (v) updateVariant(v);
    };

    /* ---- Size selector ---- */
    window.selectSize = function(el) {
      document.querySelectorAll('.size-pill').forEach(function(s) { s.classList.remove('active'); });
      el.classList.add('active');
      var v = findVariant();
      if (v) updateVariant(v);
    };

    /* ---- Pouch selector ---- */
    document.querySelectorAll('.pouch-option').forEach(function(el) {
      el.addEventListener('click', function() {
        document.querySelectorAll('.pouch-option').forEach(function(s) {
          s.classList.remove('active');
          s.querySelector('div').classList.remove('border-lc-brown');
          s.querySelector('div').classList.add('border-transparent');
          s.querySelector('span').classList.remove('text-lc-brown', 'font-medium');
          s.querySelector('span').classList.add('text-lc-taupe');
        });
        el.classList.add('active');
        el.querySelector('div').classList.remove('border-transparent');
        el.querySelector('div').classList.add('border-lc-brown');
        el.querySelector('span').classList.remove('text-lc-taupe');
        el.querySelector('span').classList.add('text-lc-brown', 'font-medium');
        var v = findVariant();
        if (v) updateVariant(v);
      });
    });

    /* ---- Accordion ---- */
    window.toggleAccordion = function(btn) {
      var content = btn.nextElementSibling;
      var arrow = btn.querySelector('svg:last-child');
      content.classList.toggle('open');
      arrow.style.transform = content.classList.contains('open') ? 'rotate(90deg)' : '';
    };

    /* ---- Reviews toggle ---- */
    window.toggleSection = function(id) {
      var section = document.getElementById(id);
      var arrow = document.getElementById(id.replace('-section', '-arrow'));
      section.classList.toggle('open');
      if (arrow) arrow.style.transform = section.classList.contains('open') ? 'rotate(90deg)' : '';
    };

    /* ---- Sticky ATC on scroll ---- */
    var mainAtc = document.getElementById('main-atc');
    var stickyAtc = document.getElementById('sticky-atc');
    var discountBar = document.getElementById('discount-bar');

    if (mainAtc && stickyAtc) {
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (!entry.isIntersecting) {
            stickyAtc.classList.add('visible');
            if (discountBar) discountBar.style.bottom = '61px';
          } else {
            stickyAtc.classList.remove('visible');
            if (discountBar) discountBar.style.bottom = '0';
          }
        });
      }, { threshold: 0 });
      observer.observe(mainAtc);
    }

    /* ---- Add to Cart (AJAX) ---- */
    window.addToCart = function() {
      var variantId = document.getElementById('variant-id').value;
      var btn = document.getElementById('main-atc');
      var originalHtml = btn.innerHTML;

      btn.disabled = true;
      btn.textContent = 'Adding...';

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: parseInt(variantId, 10), quantity: 1 }] })
      })
      .then(function(response) {
        if (!response.ok) throw new Error('Add to cart failed');
        return response.json();
      })
      .then(function() {
        btn.innerHTML = 'Added! &#10022;';
        btn.style.background = '#c9a96e';

        /* Open cart drawer if theme supports it */
        document.dispatchEvent(new CustomEvent('cart:refresh'));

        /* Update cart count in header */
        fetch(window.Shopify.routes.root + 'cart.js')
          .then(function(r) { return r.json(); })
          .then(function(cart) {
            var countEls = document.querySelectorAll('[data-cart-count]');
            countEls.forEach(function(el) { el.textContent = cart.item_count; });
          });

        setTimeout(function() {
          btn.innerHTML = originalHtml;
          btn.style.background = '#4f3c2f';
          btn.disabled = false;
        }, 1500);
      })
      .catch(function(err) {
        console.error('Add to cart error:', err);
        btn.textContent = 'Error — try again';
        btn.style.background = '#b91c1c';
        setTimeout(function() {
          btn.innerHTML = originalHtml;
          btn.style.background = '#4f3c2f';
          btn.disabled = false;
        }, 2000);
      });
    };
  })();
</script>

