{{ 'main-product.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign compare_at_price = current_variant.compare_at_price -%}
{%- assign price = current_variant.price -%}
{%- assign on_sale = false -%}
{%- if compare_at_price > price -%}
  {%- assign on_sale = true -%}
  {%- assign save_amount = compare_at_price | minus: price -%}
  {%- assign save_percent = save_amount | times: 100.0 | divided_by: compare_at_price | round -%}
{%- endif -%}

{%- comment -%} Find option positions for Metal/Color and Size {%- endcomment -%}
{%- assign color_option_index = nil -%}
{%- assign size_option_index = nil -%}
{%- for option in product.options_with_values -%}
  {%- assign option_name_down = option.name | downcase -%}
  {%- if option_name_down == 'color' or option_name_down == 'metal' or option_name_down == 'metal color' -%}
    {%- assign color_option_index = forloop.index0 -%}
    {%- assign color_option = option -%}
  {%- elsif option_name_down == 'size' -%}
    {%- assign size_option_index = forloop.index0 -%}
    {%- assign size_option = option -%}
  {%- endif -%}
{%- endfor -%}

<!-- ============================================ -->
<!-- ABOVE THE FOLD: Price/Name/Reviews (MOBILE)  -->
<!-- ============================================ -->
<div class="mobile-above-fold lg:hidden px-5 pt-4 pb-2">
  <!-- Breadcrumb -->
  <p class="text-[11px] text-lc-taupe mb-2">
    <a href="/" class="hover:text-lc-brown">Home</a>
    /
    {%- if product.collections.size > 0 -%}
      <a href="{{ product.collections.first.url }}" class="hover:text-lc-brown">{{ product.collections.first.title }}</a> /
    {%- endif -%}
    <span>{{ product.title }}</span>
  </p>
  <!-- Price row -->
  <div class="flex items-baseline gap-3">
    <span class="text-2xl font-display font-medium product-price">{{ price | money }}</span>
    {%- if on_sale -%}
      <span class="text-base text-lc-taupe line-through product-compare-price">{{ compare_at_price | money }}</span>
      <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded product-save-badge">SAVE {{ save_percent }}%</span>
    {%- endif -%}
    {%- if section.settings.show_free_shipping_badge -%}
      <span class="text-xs text-lc-gold font-medium">+ FREE Shipping</span>
    {%- endif -%}
  </div>
  <!-- Product Name -->
  <h1 class="font-display text-2xl font-medium leading-tight mt-2">{{ product.title }}</h1>
  <!-- Star rating inline -->
  <div class="flex items-center gap-2 mt-1.5">
    <div class="flex gap-0.5">
      {%- for i in (1..5) -%}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="#c9a96e" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      {%- endfor -%}
    </div>
    <span class="text-sm font-medium">{{ section.settings.review_rating | default: '4.9' }}</span>
    <a href="#reviews-full" class="text-xs text-lc-taupe underline underline-offset-2">{{ section.settings.review_count | default: 238 }} reviews</a>
  </div>
  <!-- Urgency / stock -->
  {%- if current_variant.available -%}
    <div class="flex items-center gap-2 mt-2">
      <span class="w-2 h-2 rounded-full bg-green-500 pulse-dot"></span>
      <span class="text-xs text-green-700 font-medium">In stock</span>
      {%- if section.settings.urgency_text != blank -%}
        <span class="text-xs text-lc-taupe">· {{ section.settings.urgency_text }}</span>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="flex items-center gap-2 mt-2">
      <span class="w-2 h-2 rounded-full bg-red-400"></span>
      <span class="text-xs text-red-600 font-medium">Sold out</span>
    </div>
  {%- endif -%}
</div>

<!-- ============================================ -->
<!-- IMAGE GALLERY                                -->
<!-- ============================================ -->
<div class="relative bg-lc-cream">
  <!-- Badges -->
  <div class="absolute top-3 left-3 z-10 flex gap-2">
    {%- if on_sale -%}
      <span class="image-badge bg-lc-gold text-white">{{ save_percent }}% Off</span>
    {%- endif -%}
    {%- for tag in product.tags -%}
      {%- if tag == 'best-seller' or tag == 'Best Seller' -%}
        <span class="image-badge bg-white text-lc-brown border border-[#e8e2da]">Best Seller</span>
      {%- endif -%}
    {%- endfor -%}
  </div>
  <!-- Heart / Wishlist -->
  <button class="absolute top-3 right-3 z-10 w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-sm wishlist-btn" aria-label="Add to wishlist">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
  </button>

  <div class="carousel" id="gallery">
    {%- for image in product.images -%}
      <div class="carousel-slide">
        <img
          src="{{ image | image_url: width: 1200 }}"
          srcset="{{ image | image_url: width: 600 }} 600w, {{ image | image_url: width: 900 }} 900w, {{ image | image_url: width: 1200 }} 1200w"
          sizes="(min-width: 1024px) 50vw, 100vw"
          alt="{{ image.alt | escape | default: product.title }}"
          width="{{ image.width }}"
          height="{{ image.height }}"
          loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          class="w-full aspect-square object-cover"
        >
      </div>
    {%- endfor -%}
  </div>
  <!-- Dots (mobile only) -->
  <div class="carousel-dots flex items-center justify-center gap-2 py-3 lg:hidden" id="dots"></div>
</div>

<!-- ============================================ -->
<!-- PRODUCT INFO                                 -->
<!-- ============================================ -->
<div class="max-w-3xl lg:max-w-7xl mx-auto">
  <div class="lg:grid lg:grid-cols-2 lg:gap-12">
    <!-- Desktop: spacer for gallery column -->
    <div class="hidden lg:block"></div>

    <!-- Info column -->
    <div class="px-5 py-3 lg:py-10 lg:sticky lg:top-20 lg:self-start">

      <!-- Desktop-only title (mobile shows above fold) -->
      <div class="hidden lg:block">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h1 class="font-display text-3xl font-medium leading-tight">{{ product.title }}</h1>
            <p class="text-sm text-lc-taupe mt-0.5">{{ product.type }}</p>
          </div>
        </div>
        <div class="flex items-baseline gap-3 mt-3">
          <span class="text-2xl font-display font-medium product-price">{{ price | money }}</span>
          {%- if on_sale -%}
            <span class="text-base text-lc-taupe line-through product-compare-price">{{ compare_at_price | money }}</span>
            <span class="text-xs font-semibold text-green-700 bg-green-50 px-2 py-0.5 rounded product-save-badge">SAVE {{ save_percent }}%</span>
          {%- endif -%}
        </div>
        <!-- Desktop stars -->
        <div class="flex items-center gap-2 mt-2">
          <div class="flex gap-0.5">
            {%- for i in (1..5) -%}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#c9a96e" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </div>
          <span class="text-sm font-medium">{{ section.settings.review_rating | default: '4.9' }}</span>
          <a href="#reviews-full" class="text-xs text-lc-taupe underline underline-offset-2">{{ section.settings.review_count | default: 238 }} reviews</a>
        </div>
        {%- if section.settings.klarna_enabled -%}
          <p class="text-xs text-lc-taupe mt-2">From {{ price | divided_by: 4 | money }}/mo, or 4 payments of {{ price | divided_by: 4 | money }} · <a href="#" class="underline">Learn more</a></p>
        {%- endif -%}
      </div>

      <!-- Mobile: Klarna line (compact, price already shown above fold) -->
      {%- if section.settings.klarna_enabled -%}
        <p class="lg:hidden text-xs text-lc-taupe mb-2">From {{ price | divided_by: 4 | money }}/mo, or 4 payments of {{ price | divided_by: 4 | money }} · <a href="#" class="underline">Learn more</a></p>
      {%- endif -%}

      <!-- Variant selectors form -->
      <product-form>
        <form id="product-form-{{ section.id }}" novalidate>
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id">

          <!-- Metal / Color Selector -->
          {%- if color_option -%}
            <div class="mt-3 lg:mt-5">
              <p class="text-sm font-medium mb-2">{{ color_option.name }}: <span class="font-normal text-lc-taupe" id="selected-color">{{ color_option.selected_value }}</span></p>
              <div class="flex items-center gap-3">
                {%- for value in color_option.values -%}
                  {%- assign value_down = value | downcase -%}
                  {%- assign swatch_bg = 'linear-gradient(135deg, #d4a843, #f0d68a)' -%}
                  {%- if value_down == 'silver' -%}
                    {%- assign swatch_bg = 'linear-gradient(135deg, #c0c0c0, #e8e8e8)' -%}
                  {%- elsif value_down == 'rose gold' -%}
                    {%- assign swatch_bg = 'linear-gradient(135deg, #deb3a0, #f0cbb8)' -%}
                  {%- endif -%}
                  <button
                    type="button"
                    class="swatch{% if color_option.selected_value == value %} active{% endif %}"
                    style="background: {{ swatch_bg }};"
                    data-option-position="{{ color_option.position }}"
                    data-option-value="{{ value | escape }}"
                    aria-label="{{ value }}"
                    onclick="selectSwatch(this, '{{ value | escape }}')"
                  ></button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}

          <!-- Pouch color (if product has a Pouch option) -->
          {%- for option in product.options_with_values -%}
            {%- assign opt_down = option.name | downcase -%}
            {%- if opt_down == 'pouch' or opt_down == 'pouch color' -%}
              <div class="mt-5">
                <div class="flex items-center justify-between mb-2">
                  <p class="text-sm font-medium">{{ option.name }}</p>
                </div>
                <div class="flex gap-3">
                  {%- for value in option.values -%}
                    <div class="text-center cursor-pointer pouch-option{% if option.selected_value == value %} active{% endif %}" data-option-position="{{ option.position }}" data-option-value="{{ value | escape }}">
                      <div class="w-14 h-14 rounded-lg border-2 {% if option.selected_value == value %}border-lc-brown{% else %}border-transparent{% endif %} flex items-center justify-center text-xs text-lc-taupe bg-lc-cream">{{ value }}</div>
                      <span class="text-[11px] {% if option.selected_value == value %}text-lc-brown font-medium{% else %}text-lc-taupe{% endif %} mt-1 block">{{ value }}</span>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}

          <!-- Size Selector -->
          {%- if size_option -%}
            <div class="mt-5">
              <div class="flex items-center justify-between mb-2">
                <p class="text-sm font-medium">{{ size_option.name }}</p>
                {%- if section.settings.size_guide_url != blank -%}
                  <a href="{{ section.settings.size_guide_url }}" class="text-xs text-lc-taupe underline underline-offset-2">Size Guide</a>
                {%- endif -%}
              </div>
              <div class="flex gap-2 flex-wrap">
                {%- for value in size_option.values -%}
                  <button
                    type="button"
                    class="size-pill{% if size_option.selected_value == value %} active{% endif %}"
                    data-option-position="{{ size_option.position }}"
                    data-option-value="{{ value | escape }}"
                    onclick="selectSize(this)"
                  >{{ value }}</button>
                {%- endfor -%}
              </div>
            </div>
          {%- endif -%}
        </form>
      </product-form>

      <!-- Free delivery -->
      {%- if section.settings.delivery_text != blank -%}
        <p class="flex items-center gap-2 text-sm text-lc-taupe mt-4">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          {{ section.settings.delivery_text }}
        </p>
      {%- endif -%}

      <!-- ATC Button -->
      <button
        type="button"
        class="w-full py-4 bg-lc-brown text-white font-medium text-base rounded-lg mt-5 hover:bg-lc-dark transition-colors tracking-wide"
        id="main-atc"
        onclick="addToCart()"
        {% unless current_variant.available %}disabled{% endunless %}
      >
        {%- if current_variant.available -%}
          Add to Cart &mdash; {{ price | money }}
        {%- else -%}
          Sold Out
        {%- endif -%}
      </button>

      <!-- Trust icons row -->
      <div class="flex items-center justify-center gap-5 mt-3 py-2">
        {%- for block in section.blocks -%}
          {%- if block.type == 'trust_icon' -%}
            <span class="flex items-center gap-1.5 text-[11px] text-lc-taupe" {{ block.shopify_attributes }}>
              {%- if block.settings.icon == 'waterproof' -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- elsif block.settings.icon == 'warranty' -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
              {%- elsif block.settings.icon == 'shipping' -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 3 20 16 16 16 16 8"/></svg>
              {%- endif -%}
              {{ block.settings.label }}
            </span>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Klarna callout -->
      {%- if section.settings.klarna_enabled -%}
        <div class="flex items-center gap-3 mt-2 p-3 bg-lc-cream rounded-lg">
          <span class="text-sm font-bold text-[#FFB3C7] bg-[#17120F] px-2 py-0.5 rounded text-[11px]">Klarna</span>
          <p class="text-xs text-lc-taupe">From {{ price | divided_by: 4 | money }}/month, or 4 payments at 0% interest. <a href="#" class="underline">Check purchase power</a></p>
        </div>
      {%- endif -%}

      <!-- Discount Cards (Buy 2 / Buy 3) -->
      {%- if section.settings.show_discount_cards -%}
        <div class="flex gap-3 mt-5">
          <div class="discount-card">
            <p class="text-xs text-lc-taupe mb-1">Buy 2 &rarr;</p>
            <p class="text-base font-display font-semibold">Get {{ section.settings.discount_tier_1 | default: '25' }}% Off</p>
          </div>
          <div class="discount-card">
            <p class="text-xs text-lc-taupe mb-1">Buy 3+ &rarr;</p>
            <p class="text-base font-display font-semibold">Get {{ section.settings.discount_tier_2 | default: '40' }}% Off</p>
          </div>
        </div>
      {%- endif -%}

      <!-- Reviews Summary (collapsible) -->
      <button class="w-full flex items-center justify-between py-4 mt-4 border-t border-[#f0ebe4]" onclick="toggleSection('reviews-section')">
        <div class="flex items-center gap-3">
          <span class="text-sm font-medium">Reviews ({{ section.settings.review_count | default: 238 }})</span>
          <div class="flex items-center gap-1">
            <span class="text-sm font-medium">{{ section.settings.review_rating | default: '4.9' }}</span>
            <div class="flex">
              {%- for i in (1..5) -%}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#c9a96e" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- endfor -%}
            </div>
          </div>
        </div>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="2" id="reviews-arrow"><path d="M9 18l6-6-6-6"/></svg>
      </button>
      <div class="accordion-content" id="reviews-section">
        {%- for block in section.blocks -%}
          {%- if block.type == 'inline_review' -%}
            <div class="review-card mb-3" {{ block.shopify_attributes }}>
              <div class="flex items-center justify-between mb-2">
                <div class="flex gap-0.5">
                  {%- assign stars = block.settings.stars | default: 5 -%}
                  {%- for i in (1..stars) -%}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="#c9a96e" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                  {%- endfor -%}
                </div>
                <span class="text-[11px] text-lc-taupe">{{ block.settings.date }}</span>
              </div>
              <div class="flex gap-3">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 96 }}" alt="Review photo" class="w-12 h-12 rounded-lg object-cover flex-shrink-0">
                {%- endif -%}
                <div>
                  <p class="text-sm font-medium mb-1">{{ block.settings.title }}</p>
                  <p class="text-xs text-lc-taupe leading-relaxed">{{ block.settings.body }}</p>
                  <p class="text-[11px] text-lc-taupe mt-2">{{ block.settings.author }} · <span class="text-green-700">&#10003; Verified Buyer</span></p>
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <!-- Accordion sections -->
      {%- for block in section.blocks -%}
        {%- if block.type == 'accordion' -%}
          <button class="w-full flex items-center justify-between py-4 border-t border-[#f0ebe4]{% if forloop.last %} border-b{% endif %}" onclick="toggleAccordion(this)" {{ block.shopify_attributes }}>
            <div class="flex items-center gap-3">
              {%- if block.settings.icon == 'shield' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
              {%- elsif block.settings.icon == 'info' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
              {%- elsif block.settings.icon == 'refresh' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="1.5"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
              {%- elsif block.settings.icon == 'truck' -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="1.5"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 3 20 16 16 16 16 8"/><line x1="5" y1="19" x2="19" y2="19"/></svg>
              {%- endif -%}
              <span class="text-sm font-medium">{{ block.settings.heading }}</span>
            </div>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#4f3c2f" stroke-width="2" style="transition:transform 0.3s;"><path d="M9 18l6-6-6-6"/></svg>
          </button>
          <div class="accordion-content">
            <div class="pb-4 pl-9 text-sm text-lc-taupe leading-relaxed">
              {{ block.settings.content }}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<!-- ============================================ -->
<!-- SEEN IN ACTION - Mini content slider         -->
<!-- ============================================ -->
{%- if section.settings.show_seen_in_action -%}
  <div class="px-5 pt-6 pb-4 max-w-7xl mx-auto">
    <h3 class="text-sm font-medium uppercase tracking-wider mb-3 flex items-center gap-2">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
      {{ section.settings.seen_in_action_heading | default: 'Seen in Action' }}
    </h3>
    <div class="mini-slider">
      {%- for block in section.blocks -%}
        {%- if block.type == 'action_slide' -%}
          <div class="mini-slide w-28 h-36 lg:w-32 lg:h-44" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img src="{{ block.settings.image | image_url: width: 256 }}" alt="{{ block.settings.alt | escape | default: 'Lifestyle' }}">
            {%- endif -%}
            {%- if block.settings.is_video -%}
              <div class="mini-play">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="white" stroke="none"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

<!-- ============================================ -->
<!-- COMMUNITY STATS BAR                          -->
<!-- ============================================ -->
{%- if section.settings.show_community_stats -%}
  <div class="bg-lc-dark text-white py-8 mt-6">
    <div class="max-w-4xl mx-auto px-5">
      <h3 class="text-center font-display text-xl font-medium mb-6">{{ section.settings.community_heading | default: 'Community-inspired. Customer-approved.' }}</h3>
      <div class="grid grid-cols-3 gap-4">
        <div class="stat-card">
          <div class="stat-number">{{ section.settings.stat_customers | default: '12K+' }}</div>
          <p class="text-xs text-white/60 mt-1">Happy Customers</p>
        </div>
        <div class="stat-card">
          <div class="stat-number">{{ section.settings.review_rating | default: '4.9' }}</div>
          <p class="text-xs text-white/60 mt-1">Average Rating</p>
        </div>
        <div class="stat-card">
          <div class="stat-number">{{ section.settings.review_count | default: 238 }}</div>
          <p class="text-xs text-white/60 mt-1">5-Star Reviews</p>
        </div>
      </div>
    </div>
  </div>
{%- endif -%}

<!-- ============================================ -->
<!-- REVIEW SLIDER - Horizontal scrollable cards  -->
<!-- ============================================ -->
<div class="py-10 px-5" id="reviews-full">
  <div class="max-w-7xl mx-auto">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="font-display text-2xl font-medium">{{ section.settings.reviews_heading | default: 'What Our Customers Say' }}</h2>
        <div class="flex items-center gap-2 mt-1">
          <div class="flex gap-0.5">
            {%- for i in (1..5) -%}
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#c9a96e" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- endfor -%}
          </div>
